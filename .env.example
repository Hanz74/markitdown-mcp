# ============================================================
# MarkItDown MCP Server — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ------------------------------------------------------------
# Mistral API (required for Vision, OCR, Classify, Extract)
# ------------------------------------------------------------
MISTRAL_API_KEY=your-api-key-here
MISTRAL_API_URL=https://api.mistral.ai/v1
MISTRAL_VISION_MODEL=mistral-small-2603
MISTRAL_TEXT_MODEL=mistral-small-2603
MISTRAL_OCR_MODEL=mistral-ocr-2512
MISTRAL_OCR_ENABLED=true
MISTRAL_TIMEOUT=120

# ------------------------------------------------------------
# Server Ports
# ------------------------------------------------------------
MCP_PORT=8080
REST_PORT=8081
MCP_TRANSPORT=sse

# ------------------------------------------------------------
# Limits
# ------------------------------------------------------------
MAX_FILE_SIZE_MB=25
IMAGE_MAX_WIDTH=2048
MAX_RETRIES=3
SCAN_THRESHOLD_CHARS=50

# ------------------------------------------------------------
# Token Limits
# ------------------------------------------------------------
VISION_MAX_TOKENS=16384
CLASSIFY_MAX_TOKENS=1024
EXTRACT_MAX_TOKENS=16384
OCR_CORRECT_MAX_TOKENS=16384
CLASSIFY_MAX_CHARS=32000
EXTRACT_MAX_CHARS=32000

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json

# ------------------------------------------------------------
# Language & Classification
# ------------------------------------------------------------
DEFAULT_LANGUAGE=de
CLASSIFY_CATEGORIES=invoice,contract,cv,protocol,letter,technical_doc,report,presentation,spreadsheet,other

# ------------------------------------------------------------
# Audio / Video (Whisper)
# ------------------------------------------------------------
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ------------------------------------------------------------
# Image Processing
# ------------------------------------------------------------
MIN_IMAGE_SIZE_PX=50
PDF_RENDER_DPI=200

# ------------------------------------------------------------
# Timeouts (seconds)
# ------------------------------------------------------------
PDFTOTEXT_TIMEOUT=60
PDFINFO_TIMEOUT=30
FFMPEG_TIMEOUT=600

# ------------------------------------------------------------
# Directories
# ------------------------------------------------------------
DATA_DIR=/data
TEMP_DIR=/tmp/markitdown

# ------------------------------------------------------------
# File Handling
# ------------------------------------------------------------
SKIP_FILES=email.md,consolidated.md,metadata.json,.DS_Store,Thumbs.db
